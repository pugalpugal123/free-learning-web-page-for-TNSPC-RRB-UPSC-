{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch index.html (Chrome)",
            "file": "${workspaceFolder}/index.html"
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch index.html (Edge)",
            "file": "${workspaceFolder}/index.html"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Current File",
            "file": "${file}"
        }
    ]
}